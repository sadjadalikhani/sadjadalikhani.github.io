<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td class="news-item">
              {% assign inline_content = item.content | remove: '<p>' | remove: '</p>' | emojify | strip %}
              {% if item.inline %}
                {% if item.news_url %}
                  <span class="news-title">{{ inline_content }}</span>
                  <a
                    class="news-link-icon"
                    href="{{ item.news_url }}"
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                    aria-label="Open announcement link"
                  >
                    <i class="ti ti-arrow-up-right"></i>
                  </a>
                {% else %}
                  {{ inline_content }}
                {% endif %}
              {% else %}
                <span class="news-title">{{ item.title }}</span>
                {% if item.news_url %}
                  {% assign link_url = item.news_url %}
                {% else %}
                  {% assign link_url = item.url | relative_url %}
                {% endif %}
                <a
                  class="news-link-icon"
                  href="{{ link_url }}"
                  {% if item.news_url %}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                  {% endif %}
                  aria-label="Open full announcement"
                >
                  <i class="ti ti-arrow-up-right"></i>
                </a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
